rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /appointments/{appointmentId} {
      allow create: if
        request.resource.data.source == "website" &&
        request.resource.data.status == "pending" &&
        request.resource.data.patientName is string &&
        request.resource.data.patientName.size() >= 2 &&
        request.resource.data.patientName.size() <= 100 &&
        request.resource.data.mobile is string &&
        request.resource.data.mobile.matches('^[0-9]{10}$') &&
        request.resource.data.clinicId is string &&
        request.resource.data.appointmentDate is string &&
        request.resource.data.appointmentTime is string &&
        request.resource.data.chiefComplaint is string &&
        request.resource.data.chiefComplaint.size() <= 1000;

      allow read, update, delete: if false;
    }
  }
}
