rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.uid == "z07RsgO85iU9W1kmekJGD013KqI2";
    }

    /*
     * Public website appointment booking
     */
    match /appointments/{appointmentId} {
      allow create: if
        request.resource.data.source == "website" &&
        request.resource.data.status == "pending" &&
        request.resource.data.patientName is string &&
        request.resource.data.patientName.size() >= 2 &&
        request.resource.data.patientName.size() <= 100 &&
        request.resource.data.mobile is string &&
        request.resource.data.mobile.matches('^[0-9]{10}$') &&
        request.resource.data.clinicId is string &&
        request.resource.data.appointmentDate is string &&
        request.resource.data.appointmentTime is string &&
        request.resource.data.chiefComplaint is string &&
        request.resource.data.chiefComplaint.size() <= 1000;

      allow read, update, delete: if false;
    }

    /*
     * Clinical case gallery
     */
    match /clinicalCases/{caseId} {

      // Anyone may view a case only when it is published.
      allow get, list: if resource.data.published == true;

      // Only the designated administrator can add, edit or delete.
      allow create, update, delete: if isAdmin();
    }

    /*
     * Deny access to every other collection by default.
     */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}